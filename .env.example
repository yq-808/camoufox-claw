# Instance-bound deploy defaults (copy to .env and adjust).
DEPLOY_HOST="root@YOUR_VM_IP"
DEPLOY_SSH_KEY="${HOME}/.ssh/id_ed25519"
DEPLOY_REMOTE_DIR="/home/admin/code/camoufox-claw"
DEPLOY_ADMIN_USER="admin"
DEPLOY_GATEWAY_SERVICE="openclaw-gateway.service"

# Optional deploy defaults.
DEPLOY_PROXY_SERVER=""
DEPLOY_PLAYWRIGHT_MCP_VERSION="0.0.56"

# Optional: set to 1 to change default behavior without CLI flags.
# DEPLOY_FETCH_CAMOUFOX="0"
# DEPLOY_OFFLINE_CAMOUFOX="0"
# DEPLOY_SKIP_RESTART="0"
# DEPLOY_CAMOUFOX_ASSET_URL=""
